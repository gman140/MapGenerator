@page "/game"
@rendermode InteractiveServer
@inject GameSessionService Session
@inject GameBroadcastService Broadcast
@inject MapGeneratorService MapCache
@inject PermissionService PermissionSvc
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject ICraftingRecipeProvider RecipeProvider
@using MapGenerator.Application.Services
@using MapGenerator.Domain.Enums
@using MapGenerator.Domain.Interfaces
@implements IAsyncDisposable

<PageTitle>@(Session.Player?.Username ?? "World Map")</PageTitle>

@if (!Session.IsLoaded)
{
    <div class="loading-screen"><p>Loading&hellip;</p></div>
}
else if (Session.Player == null)
{
    <div class="loading-screen"><p>Redirecting&hellip;</p></div>
}
else
{
    <div class="game-layout">
        <div class="map-area">
            <HexMapView Player="Session.Player"
                        OnTileClicked="HandleTileClickAsync"
                        OnlinePlayers="Broadcast.GetOnlinePlayers()"
                        RevealedTiles="_revealedTiles" />
        </div>
        <div class="sidebar">
            <MiniMap Player="Session.Player" MapVersion="_mapVersion"
                     RevealedTiles="_revealedTiles" RevealedVersion="_revealedVersion" />
            <PlayerInfo Player="Session.Player"
                        CooldownUntil="_cooldownUntil"
                        LastKissedAt="Session.Player.LastKissedAt"
                        OnlinePlayers="Broadcast.GetOnlinePlayersOnTile(Session.Player.Q, Session.Player.R)"
                        OnColorChanged="HandleColorChangedAsync"
                        OnKissPlayer="HandleKissPlayerAsync" />
            <InventoryModal Inventory="Session.Player.Inventory" />
            <CraftingPanel Player="Session.Player" OnCraft="HandleCraftAsync" />
            <BuildMenu Player="Session.Player"
                       CurrentTile="MapCache.GetCachedTile(Session.Player.Q, Session.Player.R)"
                       OnBuild="HandleBuildStructureAsync"
                       OnDestroy="HandleDestroyStructureAsync"
                       OnBuildRoad="HandleBuildRoadAsync" />
            <TileInventoryPanel Player="Session.Player" OnInventoryChanged="StateHasChanged" />
            @if (Session.Player.IsAdmin)
            {
                <TileEditorPanel CurrentTile="MapCache.GetCachedTile(Session.Player.Q, Session.Player.R)"
                                 OnSave="HandleEditTileAsync" />
            }
            <ActionsMenu Player="Session.Player"
                         OnLayEgg="HandleLayEggAsync"
                         OnInvestigate="HandleInvestigateAsync"
                         OnGather="HandleGatherAsync"
                         OnUsePoultice="HandleUsePoulticeAsync"
                         OnDance="HandleDanceAsync"
                         OnLeaveNote="() => { _showNoteModal = true; _noteText = string.Empty; }"
                         OnPlantSign="() => { _showSignModal = true; _signText = string.Empty; }"
                         LastEggLaidAt="Session.Player.LastEggLaidAt"
                         LastDancedAt="Session.Player.LastDancedAt"
                         GatherCooldownUntil="_gatherCooldownUntil"
                         TileHasResources="Session.TileHasResources()"
                         CooldownBypassed="PermissionSvc.GetPermissions(Session.Player).Contains(Permission.IgnoreCooldowns)" />
        </div>
        <div class="chat-area">
            <ChatPanel LocalMessages="_localMessages"
                       WorldMessages="_worldMessages"
                       OnSendLocal="SendLocalAsync"
                       OnSendWorld="SendWorldAsync" />
        </div>
    </div>

    @if (_oceanWarning)
    {
        <div class="modal-overlay">
            <div class="modal-box danger">
                <p>The ocean is treacherous and vast. Venturing in without a vessel means certain death.</p>
                <p><strong>Are you sure you want to enter the ocean?</strong></p>
                <div class="modal-actions">
                    <button class="btn-danger" @onclick="ConfirmOceanAsync">Yes, I accept my fate</button>
                    <button @onclick="() => _oceanWarning = false">Turn back</button>
                </div>
            </div>
        </div>
    }

    @if (_drownedMessage)
    {
        <div class="modal-overlay">
            <div class="modal-box danger">
                <p>The waves swallowed you whole. Your journey ends here.</p>
                <p>A new soul may yet walk this world.</p>
                <button @onclick="HandleDrownedAsync">Begin Again</button>
            </div>
        </div>
    }

    @if (_showNoteModal)
    {
        <div class="modal-overlay" @onclick="() => _showNoteModal = false">
            <div class="modal-box" @onclick:stopPropagation>
                <h3 class="modal-title">Leave a Note</h3>
                <p class="modal-hint">Your note will be hidden here, discoverable only by those who investigate this tile.</p>
                <textarea class="modal-textarea" maxlength="200" placeholder="Write your note…"
                          @bind="_noteText" @bind:event="oninput" rows="4"></textarea>
                <div class="modal-char-count">@(_noteText?.Length ?? 0) / 200</div>
                <div class="modal-actions">
                    <button @onclick="HandleLeaveNoteAsync" disabled="@string.IsNullOrWhiteSpace(_noteText)">Leave Note</button>
                    <button @onclick="() => _showNoteModal = false">Cancel</button>
                </div>
            </div>
        </div>
    }

    @if (_showSignModal)
    {
        <div class="modal-overlay" @onclick="() => _showSignModal = false">
            <div class="modal-box" @onclick:stopPropagation>
                <h3 class="modal-title">Plant a Sign</h3>
                <p class="modal-hint">Your sign will be visible to anyone who enters this tile. It replaces any existing sign.</p>
                <textarea class="modal-textarea" maxlength="100" placeholder="Write your sign…"
                          @bind="_signText" @bind:event="oninput" rows="3"></textarea>
                <div class="modal-char-count">@(_signText?.Length ?? 0) / 100</div>
                <div class="modal-actions">
                    <button @onclick="HandlePlantSignAsync" disabled="@string.IsNullOrWhiteSpace(_signText)">Plant Sign</button>
                    <button @onclick="() => _showSignModal = false">Cancel</button>
                </div>
            </div>
        </div>
    }

    @if (_moveError != null)
    {
        <div class="toast-error">@_moveError</div>
    }
}

@code {
    private List<ChatMessage> _localMessages = [];
    private List<ChatMessage> _worldMessages = [];
    private long _cooldownUntil;
    private long _gatherCooldownUntil;
    private bool _oceanWarning;
    private bool _drownedMessage;
    private string? _moveError;
    private (int q, int r)? _pendingOceanMove;
    private System.Threading.Timer? _toastTimer;
    private int _mapVersion;

    private HashSet<(int, int)>? _revealedTiles;
    private int _revealedVersion;

    private bool _showNoteModal;
    private bool _showSignModal;
    private string _noteText = string.Empty;
    private string _signText = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var browserId = await JS.InvokeAsync<string>("gameJs.getBrowserId");
        await Session.InitAsync(browserId);

        if (Session.Player == null)
        {
            Nav.NavigateTo("/");
            return;
        }

        _cooldownUntil       = Session.Player.MovementCooldownUntil;
        _gatherCooldownUntil = Session.Player.GatherCooldownUntil;
        _localMessages = await Session.GetTileChatAsync();
        AddArrivalMessages(Session.Player.Q, Session.Player.R);
        _worldMessages = await Session.GetWorldChatAsync();
        _revealedTiles = await Session.LoadRevealedTilesAsync();

        Broadcast.PlayerMoved        += OnPlayerMoved;
        Broadcast.MessageReceived    += OnMessageReceived;
        Broadcast.MapRegenerated     += OnMapRegenerated;
        Broadcast.EggLaid            += OnEggLaid;
        Broadcast.PlayerDanced       += OnPlayerDanced;
        Broadcast.PlayerKissed       += OnPlayerKissed;
        Broadcast.PlayerColorChanged += OnPlayerColorChanged;
        Broadcast.RoadsChanged       += OnRoadsChanged;
        Broadcast.EggExploded        += OnEggExploded;

        await JS.InvokeVoidAsync("gameJs.initMinimap", Session.Player.Q, Session.Player.R);
        StateHasChanged();
    }

    private async Task HandleBuildRoadAsync()
    {
        var (success, error) = await Session.BuildRoadAsync();
        if (!success) { ShowToast(error ?? "Cannot build road here."); return; }
        _localMessages.Add(new ChatMessage
        {
            SenderName = "World", Content = "You lay down a road here.",
            IsSystemMessage = true, SentAt = DateTime.UtcNow
        });
        StateHasChanged();
    }

    private async Task HandleTileClickAsync((int q, int r) target)
    {
        if (Session.Player == null) return;
        _moveError = null;

        var result = await Session.MoveAsync(target.q, target.r);

        if (result.RequiresOceanConfirmation)
        {
            _pendingOceanMove = target;
            _oceanWarning = true;
            StateHasChanged();
            return;
        }

        if (result.PlayerDrowned)
        {
            _drownedMessage = true;
            StateHasChanged();
            return;
        }

        if (!result.Success)
        {
            ShowToast(result.ErrorMessage ?? "Cannot move there.");
            return;
        }

        _cooldownUntil = result.CooldownUntil ?? 0;
        _localMessages = await Session.GetTileChatAsync();
        AddArrivalMessages(Session.Player!.Q, Session.Player.R);
        RevealTile(Session.Player.Q, Session.Player.R);
        await Session.ConsumeGardenProductionAsync();

        var (exploded, explosionMsg) = await Session.TryExplodeEggsAsync();
        if (exploded)
        {
            _localMessages.Add(new ChatMessage
            {
                SenderName = "World", Content = explosionMsg,
                IsSystemMessage = true, SentAt = DateTime.UtcNow
            });
            _mapVersion++;
        }

        await JS.InvokeVoidAsync("gameJs.updateMinimapPlayer", Session.Player.Q, Session.Player.R);
        StateHasChanged();
    }

    private void RevealRadius(int centerQ, int centerR, int radius)
    {
        if (_revealedTiles == null) return;
        for (int dq = -radius; dq <= radius; dq++)
            for (int dr = Math.Max(-radius, -dq - radius); dr <= Math.Min(radius, -dq + radius); dr++)
                _revealedTiles.Add((centerQ + dq, centerR + dr));
        _revealedVersion++;
    }

    private void RevealTile(int q, int r)
    {
        if (_revealedTiles == null) return;
        _revealedTiles.Add((q, r));
        bool extended = Session.Player != null && RecipeProvider.PlayerHasEffect(Session.Player, ItemEffect.ExtendRevealRadius);
        foreach (var (dq, dr) in MapGeneratorService.HexNeighborOffsets())
        {
            int nq = q + dq, nr = r + dr;
            _revealedTiles.Add((nq, nr));
            if (extended)
                foreach (var (dq2, dr2) in MapGeneratorService.HexNeighborOffsets())
                    _revealedTiles.Add((nq + dq2, nr + dr2));
        }
        _revealedVersion++;
    }

    private void AddArrivalMessages(int q, int r)
    {
        var tile = MapCache.GetCachedTile(q, r);
        if (tile == null) return;

        if (tile.EggCount > 0)
            _localMessages.Add(new ChatMessage
            {
                SenderName = "World", Content = EggService.GetEggDescriptor(tile.EggCount),
                IsSystemMessage = true, SentAt = DateTime.UtcNow
            });

        if (!string.IsNullOrEmpty(tile.SignText))
            _localMessages.Add(new ChatMessage
            {
                SenderName = "World",
                Content = $"A sign planted by {tile.SignAuthor} reads: \"{tile.SignText}\"",
                IsSystemMessage = true, SentAt = DateTime.UtcNow
            });

        if (tile.Structure != null)
            _localMessages.Add(new ChatMessage
            {
                SenderName = "World",
                Content = $"A {StructureNames[tile.Structure.Type]} stands here, built by {tile.Structure.BuilderName}.",
                IsSystemMessage = true, SentAt = DateTime.UtcNow
            });
    }

    private static readonly Dictionary<StructureType, string> StructureNames = new()
    {
        [StructureType.Beacon]    = "Beacon",
        [StructureType.Garden]    = "Garden",
        [StructureType.MineShaft] = "Mine Shaft",
        [StructureType.Workshop]  = "Workshop",
        [StructureType.Dock]      = "Dock",
    };

    private async Task ConfirmOceanAsync()
    {
        _oceanWarning = false;
        if (_pendingOceanMove == null) return;
        var (q, r) = _pendingOceanMove.Value;
        _pendingOceanMove = null;

        var result = await Session.MoveAsync(q, r, oceanConfirmed: true);
        if (result.PlayerDrowned)
        {
            _drownedMessage = true;
            StateHasChanged();
            return;
        }
        if (result.Success && Session.Player != null)
        {
            RevealTile(Session.Player.Q, Session.Player.R);
            await JS.InvokeVoidAsync("gameJs.updateMinimapPlayer", Session.Player.Q, Session.Player.R);
        }
        StateHasChanged();
    }

    private async Task HandleDrownedAsync()
    {
        await JS.InvokeVoidAsync("gameJs.clearBrowserId");
        Nav.NavigateTo("/", forceLoad: true);
    }

    private async Task HandleLayEggAsync()
    {
        var (_, message, _) = await Session.LayEggAsync();
        _localMessages.Add(new ChatMessage
        {
            SenderName = "World", Content = message,
            IsSystemMessage = true, SentAt = DateTime.UtcNow
        });
        StateHasChanged();
    }

    private async Task HandleDanceAsync()
    {
        var (success, message, _, _) = await Session.DanceAsync();
        if (!success) return;
        _localMessages.Add(new ChatMessage
        {
            SenderName = "World", Content = message,
            IsSystemMessage = true, SentAt = DateTime.UtcNow
        });
        StateHasChanged();
    }

    private async Task HandleBuildStructureAsync(StructureType type)
    {
        var (success, error) = await Session.BuildStructureAsync(type);
        if (!success)
        {
            ShowToast(error ?? "Cannot build here.");
            return;
        }
        var tile = MapCache.GetCachedTile(Session.Player!.Q, Session.Player.R);
        var structureName = StructureNames.GetValueOrDefault(type, type.ToString());
        _localMessages.Add(new ChatMessage
        {
            SenderName = "World", Content = $"You build a {structureName} here.",
            IsSystemMessage = true, SentAt = DateTime.UtcNow
        });
        if (type == StructureType.Beacon) _mapVersion++;
        StateHasChanged();
    }

    private async Task HandleDestroyStructureAsync()
    {
        var tile = MapCache.GetCachedTile(Session.Player!.Q, Session.Player.R);
        var structureType = tile?.Structure?.Type;
        var success = await Session.DestroyStructureAsync();
        if (!success) return;
        var structureName = structureType.HasValue ? StructureNames.GetValueOrDefault(structureType.Value, structureType.ToString()!) : "structure";
        _localMessages.Add(new ChatMessage
        {
            SenderName = "World", Content = $"You tear down the {structureName}.",
            IsSystemMessage = true, SentAt = DateTime.UtcNow
        });
        if (structureType == StructureType.Beacon) _mapVersion++;
        StateHasChanged();
    }

    private async Task HandleCraftAsync(string recipeId)
    {
        var result = await Session.CraftAsync(recipeId);
        if (!result.Success)
        {
            ShowToast(result.ErrorMessage ?? "Could not craft that.");
            return;
        }
        _localMessages.Add(new ChatMessage
        {
            SenderName = "World", Content = $"You craft: {result.CraftedItemName}.",
            IsSystemMessage = true, SentAt = DateTime.UtcNow
        });
        StateHasChanged();
    }

    private async Task HandleUsePoulticeAsync()
    {
        var success = await Session.UsePoulticeAsync();
        if (!success) return;
        _cooldownUntil = 0;
        _localMessages.Add(new ChatMessage
        {
            SenderName = "World", Content = "You apply the poultice. The ache fades.",
            IsSystemMessage = true, SentAt = DateTime.UtcNow
        });
        StateHasChanged();
    }

    private async Task HandleGatherAsync()
    {
        var result = await Session.GatherAsync();
        _gatherCooldownUntil = Session.Player?.GatherCooldownUntil ?? 0;

        if (!result.Success)
        {
            ShowToast(result.ErrorMessage ?? "Cannot gather here.");
            return;
        }

        var message = result.Gathered.Count == 0
            ? "You search carefully but find nothing worth taking."
            : "You gather: " + string.Join(", ", result.Gathered.Select(g => $"{g.Quantity}× {g.Name}")) + ".";

        _localMessages.Add(new ChatMessage
        {
            SenderName = "World", Content = message,
            IsSystemMessage = true, SentAt = DateTime.UtcNow
        });
        StateHasChanged();
    }

    private async Task HandleInvestigateAsync()
    {
        var (flavorText, notes) = await Session.InvestigateAsync();
        _localMessages.Add(new ChatMessage
        {
            SenderName = "World", Content = flavorText,
            IsSystemMessage = true, SentAt = DateTime.UtcNow
        });
        foreach (var note in notes)
        {
            _localMessages.Add(new ChatMessage
            {
                SenderName = "World",
                Content = $"📜 {note.AuthorName} wrote: \"{note.Content}\"",
                IsSystemMessage = true, SentAt = DateTime.UtcNow
            });
        }

        if (Session.Player != null)
        {
            var tile = MapCache.GetCachedTile(Session.Player.Q, Session.Player.R);
            if (tile?.Structure?.Type == StructureType.Beacon)
            {
                RevealRadius(Session.Player.Q, Session.Player.R, 9);
                _localMessages.Add(new ChatMessage
                {
                    SenderName = "World",
                    Content = "The beacon's light reaches far. You can see the surrounding land clearly now.",
                    IsSystemMessage = true, SentAt = DateTime.UtcNow
                });
            }
        }

        StateHasChanged();
    }

    private async Task HandleLeaveNoteAsync()
    {
        _showNoteModal = false;
        if (string.IsNullOrWhiteSpace(_noteText)) return;
        await Session.LeaveNoteAsync(_noteText);
        _localMessages.Add(new ChatMessage
        {
            SenderName = "World", Content = "You tuck a note away somewhere only the curious will find it.",
            IsSystemMessage = true, SentAt = DateTime.UtcNow
        });
        _noteText = string.Empty;
        StateHasChanged();
    }

    private async Task HandlePlantSignAsync()
    {
        _showSignModal = false;
        if (string.IsNullOrWhiteSpace(_signText)) return;
        await Session.PlantSignAsync(_signText);
        _localMessages.Add(new ChatMessage
        {
            SenderName = "World",
            Content = $"You plant a sign that reads: \"{_signText}\"",
            IsSystemMessage = true, SentAt = DateTime.UtcNow
        });
        _signText = string.Empty;
        StateHasChanged();
    }

    private async Task HandleEditTileAsync((BiomeType biome, string? featureId) args)
    {
        var (success, error) = await Session.EditTileAsync(args.biome, args.featureId);
        if (!success) { ShowToast(error ?? "Could not edit tile."); return; }
        _mapVersion++;
        StateHasChanged();
    }

    private async Task HandleColorChangedAsync(string color)
    {
        await Session.UpdateColorAsync(color);
        StateHasChanged();
    }

    private async Task SendLocalAsync(string content) =>
        await Session.SendLocalMessageAsync(content);

    private async Task SendWorldAsync(string content) =>
        await Session.SendWorldMessageAsync(content);

    private void OnPlayerMoved(string playerId, int oldQ, int oldR, int newQ, int newR) =>
        InvokeAsync(StateHasChanged);

    private void OnPlayerColorChanged(string playerId, string color) =>
        InvokeAsync(StateHasChanged);

    private void OnMessageReceived(ChatMessage msg)
    {
        InvokeAsync(() =>
        {
            if (msg.IsWorldChat)
                _worldMessages.Add(msg);
            else if (Session.Player != null && msg.TileQ == Session.Player.Q && msg.TileR == Session.Player.R)
                _localMessages.Add(msg);
            StateHasChanged();
        });
    }

    private void OnEggLaid(string playerId, int q, int r, int eggCount)
    {
        InvokeAsync(() =>
        {
            if (Session.Player == null || Session.Player.Q != q || Session.Player.R != r) return;
            if (playerId == Session.Player.Id) return;
            _localMessages.Add(new ChatMessage
            {
                SenderName = "World", Content = EggService.GetEggDescriptor(eggCount),
                IsSystemMessage = true, SentAt = DateTime.UtcNow
            });
            StateHasChanged();
        });
    }

    private void OnPlayerDanced(string playerId, string username, int q, int r)
    {
        InvokeAsync(() =>
        {
            if (Session.Player == null || Session.Player.Q != q || Session.Player.R != r) return;
            if (playerId == Session.Player.Id) return;
            _localMessages.Add(new ChatMessage
            {
                SenderName = "World", Content = $"{username} is dancing.",
                IsSystemMessage = true, SentAt = DateTime.UtcNow
            });
            StateHasChanged();
        });
    }

    private void OnPlayerKissed(string kisserId, string kisserName, string kisseeId, string kisseeName, int q, int r, string kisseeMsg, string observerMsg)
    {
        InvokeAsync(() =>
        {
            if (Session.Player == null || Session.Player.Q != q || Session.Player.R != r) return;
            if (Session.Player.Id == kisserId) return; // kisser sees their own message locally
            string msg = Session.Player.Id == kisseeId ? kisseeMsg : observerMsg;
            _localMessages.Add(new ChatMessage
            {
                SenderName = "World", Content = msg,
                IsSystemMessage = true, SentAt = DateTime.UtcNow
            });
            StateHasChanged();
        });
    }

    private async Task HandleKissPlayerAsync((string Id, string Username) target)
    {
        var (success, msg) = await Session.KissAsync(target.Id, target.Username);
        if (!success)
        {
            ShowToast(msg);
            return;
        }
        _localMessages.Add(new ChatMessage
        {
            SenderName = "World", Content = msg,
            IsSystemMessage = true, SentAt = DateTime.UtcNow
        });
        StateHasChanged();
    }

    private void OnRoadsChanged() => InvokeAsync(StateHasChanged);

    private void OnEggExploded(string playerId, int q, int r)
    {
        InvokeAsync(() =>
        {
            if (Session.Player == null || Session.Player.Id == playerId) return;
            _localMessages.Add(new ChatMessage
            {
                SenderName = "World",
                Content = "You hear a distant explosion and feel a sudden, inexplicable sense of loss.",
                IsSystemMessage = true, SentAt = DateTime.UtcNow
            });
            _mapVersion++;
            StateHasChanged();
        });
    }

    private void OnMapRegenerated(MapConfig config)
    {
        InvokeAsync(async () =>
        {
            if (Session.Player == null) return;
            await Session.HandleMapResetAsync();
            _localMessages = await Session.GetTileChatAsync();
            _localMessages.Add(new ChatMessage
            {
                SenderName = "System",
                Content = "You saw a bright flash, and the world faded away. You woke up here.",
                IsSystemMessage = true, SentAt = DateTime.UtcNow
            });
            _revealedTiles = await Session.LoadRevealedTilesAsync();
            _revealedVersion++;
            _mapVersion++;
            StateHasChanged();
        });
    }

    private void ShowToast(string message)
    {
        _moveError = message;
        _toastTimer?.Dispose();
        _toastTimer = new System.Threading.Timer(_ =>
        {
            _moveError = null;
            InvokeAsync(StateHasChanged);
        }, null, 3000, Timeout.Infinite);
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        Broadcast.PlayerMoved        -= OnPlayerMoved;
        Broadcast.MessageReceived    -= OnMessageReceived;
        Broadcast.MapRegenerated     -= OnMapRegenerated;
        Broadcast.EggLaid            -= OnEggLaid;
        Broadcast.PlayerDanced       -= OnPlayerDanced;
        Broadcast.PlayerKissed       -= OnPlayerKissed;
        Broadcast.PlayerColorChanged -= OnPlayerColorChanged;
        Broadcast.RoadsChanged       -= OnRoadsChanged;
        Broadcast.EggExploded        -= OnEggExploded;
        _toastTimer?.Dispose();
        await Session.DisposeAsync();
    }
}
