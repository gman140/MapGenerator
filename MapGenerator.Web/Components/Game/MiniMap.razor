@using MapGenerator.Application.Services
@inject MapGeneratorService MapCache
@inject IJSRuntime JS

<div class="minimap-container" @onclick="() => _showPopup = true" title="Click to expand">
    <canvas @ref="_canvas" id="minimap-canvas" class="minimap-canvas"></canvas>
</div>

@if (_showPopup)
{
    <div class="modal-overlay" @onclick="() => _showPopup = false">
        <div class="minimap-popup" @onclick:stopPropagation>
            <div class="minimap-popup-header">
                <span>World Map</span>
                <button @onclick="() => _showPopup = false">✕</button>
            </div>
            <canvas @ref="_popupCanvas" class="minimap-popup-canvas"></canvas>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public Player Player { get; set; } = null!;
    [Parameter] public int MapVersion { get; set; }
    [Parameter] public IReadOnlySet<(int, int)>? RevealedTiles { get; set; }

    private ElementReference _canvas;
    private ElementReference _popupCanvas;
    private bool _showPopup;
    private bool _needsFullRedraw = true;
    private int _lastMapVersion = -1;

    protected override void OnParametersSet()
    {
        if (MapVersion != _lastMapVersion)
        {
            _lastMapVersion = MapVersion;
            _needsFullRedraw = true;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_needsFullRedraw || firstRender)
        {
            var config = MapCache.GetCachedConfig();
            if (config == null) return;

            var rgbData = MapCache.GetMinimapData(RevealedTiles);
            if (rgbData.Length == 0) return;

            await JS.InvokeVoidAsync("gameJs.drawMinimap",
                _canvas, rgbData, config.Width, config.Height, Player.Q, Player.R);

            _needsFullRedraw = false;
        }

        if (_showPopup)
        {
            await JS.InvokeVoidAsync("gameJs.openMinimapPopup", _popupCanvas, Player.Q, Player.R);
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_needsFullRedraw) return;
        await JS.InvokeVoidAsync("gameJs.updateMinimapPlayer", Player.Q, Player.R);
    }
}
