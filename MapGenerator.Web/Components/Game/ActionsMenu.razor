@implements IDisposable

<div class="actions-menu">
    <button class="action-item" @onclick="HandleInvestigate">🔍 Investigate</button>
    <button class="action-item" @onclick="HandleLeaveNote">📝 Leave a Note</button>
    <button class="action-item" @onclick="HandlePlantSign">🪧 Plant a Sign</button>
    <div class="action-divider"></div>
    <button class="action-item" @onclick="HandleGather"
            disabled="@(!TileHasResources || GatherOnCooldown)">
        ⛏ Gather
        @if (GatherOnCooldown)
        {
            <span class="action-cooldown">@_gatherCooldownText</span>
        }
        else if (!TileHasResources)
        {
            <span class="action-cooldown">nothing here</span>
        }
    </button>
    <button class="action-item" @onclick="LayEgg" disabled="@EggOnCooldown">
        🥚 Lay Egg
        @if (EggOnCooldown)
        {
            <span class="action-cooldown">@_eggCooldownText</span>
        }
    </button>
    <button class="action-item" disabled>💃 Dance <span class="action-soon">soon</span></button>
</div>

@code {
    [Parameter] public EventCallback OnLayEgg { get; set; }
    [Parameter] public EventCallback OnInvestigate { get; set; }
    [Parameter] public EventCallback OnLeaveNote { get; set; }
    [Parameter] public EventCallback OnPlantSign { get; set; }
    [Parameter] public EventCallback OnGather { get; set; }
    [Parameter] public DateTime? LastEggLaidAt { get; set; }
    [Parameter] public bool CooldownBypassed { get; set; }
    [Parameter] public long GatherCooldownUntil { get; set; }
    [Parameter] public bool TileHasResources { get; set; }

    private bool EggOnCooldown => !CooldownBypassed && LastEggLaidAt.HasValue && (DateTime.UtcNow - LastEggLaidAt.Value).TotalMinutes < 1;
    private bool GatherOnCooldown => !CooldownBypassed && DateTimeOffset.UtcNow.ToUnixTimeMilliseconds() < GatherCooldownUntil;
    private string _eggCooldownText = "";
    private string _gatherCooldownText = "";
    private System.Threading.Timer? _timer;

    protected override void OnParametersSet()
    {
        bool needsTimer = EggOnCooldown || GatherOnCooldown;
        if (needsTimer)
        {
            UpdateCooldownTexts();
            _timer ??= new System.Threading.Timer(Tick, null, 100, 100);
        }
        else
        {
            _timer?.Dispose();
            _timer = null;
        }
    }

    private void Tick(object? _)
    {
        UpdateCooldownTexts();
        if (!EggOnCooldown && !GatherOnCooldown) { _timer?.Dispose(); _timer = null; }
        InvokeAsync(StateHasChanged);
    }

    private void UpdateCooldownTexts()
    {
        if (LastEggLaidAt.HasValue)
        {
            var remaining = TimeSpan.FromMinutes(1) - (DateTime.UtcNow - LastEggLaidAt.Value);
            _eggCooldownText = remaining > TimeSpan.Zero ? $"({remaining.TotalSeconds:F0}s)" : "";
        }

        long now = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
        if (GatherCooldownUntil > now)
        {
            double secs = (GatherCooldownUntil - now) / 1000.0;
            _gatherCooldownText = $"({secs:F1}s)";
        }
        else
        {
            _gatherCooldownText = "";
        }
    }

    private async Task LayEgg()            { await OnLayEgg.InvokeAsync(); }
    private async Task HandleInvestigate() { await OnInvestigate.InvokeAsync(); }
    private async Task HandleLeaveNote()   { await OnLeaveNote.InvokeAsync(); }
    private async Task HandlePlantSign()   { await OnPlantSign.InvokeAsync(); }
    private async Task HandleGather()      { await OnGather.InvokeAsync(); }

    public void Dispose() => _timer?.Dispose();
}
