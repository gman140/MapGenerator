@using MapGenerator.Application.Services
@using MapGenerator.Domain.Interfaces
@inject MapGeneratorService MapCache
@inject IFeatureDefinitionProvider FeatureProvider
@inject SettlementCacheService SettlementCache
@using static MapGenerator.Application.Services.DanceService
@implements IDisposable

<div class="player-info">
    <div class="player-name">
        <label class="color-swatch-label" title="Change your color">
            <input type="color" value="@Player.Color" @onchange="HandleColorChange" class="color-swatch-input" />
            <span class="color-swatch" style="background: @Player.Color"></span>
        </label>
        <span>@Player.Username</span>
        @if (Player.IsAdmin) { <span class="admin-badge">admin</span> }
        @{ var selfTitle = GetTitle(Player.EggsDestroyed); }
        @if (selfTitle != null) { <span class="egg-title">@selfTitle</span> }
    </div>
    <div class="tile-info">
        @{
            var tile = MapCache.GetCachedTile(Player.Q, Player.R);
            var featureDef = FeatureProvider.GetById(tile?.FeatureId);
            var (settlementName, _) = SettlementCache.GetSettlementTile(Player.Q, Player.R);
        }
        <span class="biome-tag biome-@(tile?.Biome.ToString().ToLower() ?? "unknown")">
            @(tile?.Biome.ToString() ?? "Unknown")
        </span>
        @if (featureDef != null)
        {
            <span class="feature-tag">@featureDef.GetDisplayName(Player.Q, Player.R)</span>
        }
        @if (settlementName != null)
        {
            <span class="settlement-tag">@settlementName</span>
        }
        <span class="coords">(@Player.Q, @Player.R)</span>
    </div>

    @if (_cooldownRemaining > 0)
    {
        <div class="cooldown-bar">
            <div class="cooldown-fill" style="width: @_fillPct%"></div>
            <span class="cooldown-text">@((_cooldownRemaining / 1000.0).ToString("F1"))s</span>
        </div>
    }

    @if (OnlinePlayers.Count > 0)
    {
        <div class="players-here">
            <span class="section-label">Here:</span>
            @foreach (var (id, username, eggsDestroyed) in OnlinePlayers)
            {
                <span class="player-chip @(id == Player.Id ? "self" : "")">
                    @username
                    @{ var chipTitle = GetTitle(eggsDestroyed); }
                    @if (chipTitle != null)
                    {
                        <span class="egg-title-small">@chipTitle</span>
                    }
                    @if (id != Player.Id)
                    {
                        var capturedId = id;
                        var capturedName = username;
                        <button class="kiss-btn" disabled="@(_kissRemainingMs > 0)"
                                @onclick="async () => await OnKissPlayer.InvokeAsync((capturedId, capturedName))">
                            @(_kissRemainingMs > 0 ? $"💋 {(_kissRemainingMs / 1000.0):F0}s" : "💋")
                        </button>
                    }
                </span>
            }
        </div>
    }

    @if (Player.IsAdmin)
    {
        <a href="/admin" class="admin-link">Admin Panel</a>
    }
</div>

@code {
    private static readonly TimeSpan KissCooldown = TimeSpan.FromMinutes(1);

    [Parameter, EditorRequired] public Player Player { get; set; } = null!;
    [Parameter] public long CooldownUntil { get; set; }
    [Parameter] public DateTime? LastKissedAt { get; set; }
    [Parameter] public List<(string Id, string Username, int EggsDestroyed)> OnlinePlayers { get; set; } = [];
    [Parameter] public EventCallback<string> OnColorChanged { get; set; }
    [Parameter] public EventCallback<(string Id, string Username)> OnKissPlayer { get; set; }

    private long _cooldownRemaining;
    private double _fillPct;
    private long _cooldownDuration;
    private long _kissRemainingMs;
    private long _kissEndMs;
    private System.Threading.Timer? _timer;
    protected override void OnParametersSet()
    {
        long now = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
        _cooldownRemaining = Math.Max(0, CooldownUntil - now);
        _cooldownDuration = _cooldownRemaining > 0 ? _cooldownRemaining : _cooldownDuration;
        UpdateFill();

        if (LastKissedAt.HasValue)
        {
            _kissEndMs = new DateTimeOffset(LastKissedAt.Value.ToUniversalTime()).ToUnixTimeMilliseconds()
                         + (long)KissCooldown.TotalMilliseconds;
            _kissRemainingMs = Math.Max(0, _kissEndMs - now);
        }
        else
        {
            _kissRemainingMs = 0;
            _kissEndMs = 0;
        }

        bool needsTimer = _cooldownRemaining > 0 || _kissRemainingMs > 0;
        if (needsTimer && _timer == null)
            _timer = new System.Threading.Timer(Tick, null, 100, 100);
        else if (!needsTimer)
        {
            _timer?.Dispose();
            _timer = null;
        }
    }

    private void Tick(object? _)
    {
        long now = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
        _cooldownRemaining = Math.Max(0, CooldownUntil - now);
        _kissRemainingMs   = Math.Max(0, _kissEndMs - now);
        UpdateFill();

        if (_cooldownRemaining <= 0 && _kissRemainingMs <= 0)
        {
            _timer?.Dispose();
            _timer = null;
        }
        InvokeAsync(StateHasChanged);
    }

    private void UpdateFill()
    {
        _fillPct = _cooldownDuration > 0
            ? _cooldownRemaining / (double)_cooldownDuration * 100.0
            : 0;
    }

    private async Task HandleColorChange(ChangeEventArgs e)
    {
        var color = e.Value?.ToString();
        if (!string.IsNullOrEmpty(color))
            await OnColorChanged.InvokeAsync(color);
    }

    public void Dispose() => _timer?.Dispose();
}
