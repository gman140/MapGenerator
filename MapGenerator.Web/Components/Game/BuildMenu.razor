@using MapGenerator.Domain.Enums
@using MapGenerator.Domain.Interfaces
@using MapGenerator.Domain.Models
@inject IStructureDefinitionProvider StructureProvider
@inject IResourceDefinitionProvider ResourceProvider

<button class="crafting-toggle" @onclick="() => _open = true">
    <span>🏗️ Build</span>
</button>

@if (_open)
{
    <div class="modal-overlay" @onclick="() => _open = false">
        <div class="modal-box crafting-modal" @onclick:stopPropagation>
            <div class="crafting-modal-header">
                <h3 class="modal-title">Build</h3>
                <button class="crafting-modal-close" @onclick="() => _open = false">✕</button>
            </div>

            @{
                Player.Inventory.TryGetValue("Wood",  out int roadWood);
                Player.Inventory.TryGetValue("Stone", out int roadStone);
                bool canAffordRoad = roadWood >= 3 && roadStone >= 2;
            }
            <div class="recipe-card" style="margin-bottom:.25rem">
                <div class="recipe-header">
                    <span class="recipe-name">Road Segment</span>
                    <button class="recipe-craft-btn" disabled="@(!canAffordRoad)"
                            @onclick="async () => { await OnBuildRoad.InvokeAsync(); _open = false; }">
                        Build
                    </button>
                </div>
                <p class="inv-modal-desc">A short stretch of road to an adjacent tile.</p>
                <div class="recipe-ingredients">
                    <span class="ingredient @(roadWood >= 3 ? "ingredient-ok" : "ingredient-missing")">Wood @roadWood/3</span>
                    <span class="ingredient @(roadStone >= 2 ? "ingredient-ok" : "ingredient-missing")">Stone @roadStone/2</span>
                </div>
            </div>

            @if (CurrentTile?.Structure != null)
            {
                var existing = StructureProvider.GetByType(CurrentTile.Structure.Type);
                <div class="structure-existing">
                    <div class="structure-existing-info">
                        <span class="structure-existing-name">@(existing?.Name ?? CurrentTile.Structure.Type.ToString())</span>
                        <span class="structure-existing-builder">built by @CurrentTile.Structure.BuilderName</span>
                    </div>
                    <button class="structure-destroy-btn" @onclick="HandleDestroy">Destroy</button>
                </div>
                <p class="structure-existing-desc">@existing?.Description</p>
            }
            else
            {
                <div class="crafting-recipes">
                    @foreach (var def in StructureProvider.All)
                    {
                        bool wrongBiome = def.AllowedBiomes != null &&
                                          (CurrentTile == null || !def.AllowedBiomes.Contains(CurrentTile.Biome));
                        bool canAfford  = !wrongBiome && def.Ingredients.All(i =>
                        {
                            Player.Inventory.TryGetValue(i.ResourceId, out int have);
                            return have >= i.Quantity;
                        });
                        bool canBuild = canAfford && !wrongBiome;

                        <div class="recipe-card">
                            <div class="recipe-header">
                                <span class="recipe-name">@def.Name</span>
                                <button class="recipe-craft-btn" disabled="@(!canBuild)"
                                        @onclick="() => HandleBuild(def.Type)">
                                    Build
                                </button>
                            </div>
                            <p class="inv-modal-desc">@def.Description</p>
                            <div class="recipe-ingredients">
                                @if (wrongBiome)
                                {
                                    <span class="ingredient ingredient-missing">wrong biome</span>
                                }
                                else
                                {
                                    @foreach (var ing in def.Ingredients)
                                    {
                                        Player.Inventory.TryGetValue(ing.ResourceId, out int have);
                                        bool ok = have >= ing.Quantity;
                                        var name = ResourceProvider.GetById(ing.ResourceId)?.Name ?? ing.ResourceId;
                                        <span class="ingredient @(ok ? "ingredient-ok" : "ingredient-missing")">
                                            @name @have/@ing.Quantity
                                        </span>
                                    }
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public Player Player { get; set; } = null!;
    [Parameter] public HexTile? CurrentTile { get; set; }
    [Parameter] public EventCallback<StructureType> OnBuild { get; set; }
    [Parameter] public EventCallback OnDestroy { get; set; }
    [Parameter] public EventCallback OnBuildRoad { get; set; }

    private bool _open;

    private async Task HandleBuild(StructureType type)
    {
        await OnBuild.InvokeAsync(type);
        _open = false;
    }

    private async Task HandleDestroy()
    {
        await OnDestroy.InvokeAsync();
        _open = false;
    }
}
