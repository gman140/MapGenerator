@using MapGenerator.Application.Services
@using MapGenerator.Domain.Interfaces
@inject MapGeneratorService MapCache
@inject IFeatureDefinitionProvider FeatureProvider

<div class="hex-map-container" @ref="_container">
    <svg width="@_svgWidth" height="@_svgHeight"
         class="hex-map-svg"
         @onmousemove="HandleMouseMove"
         @onmouseleave="() => _hoveredTile = null">

        @for (int dq = -ViewRadius; dq <= ViewRadius; dq++)
        {
            @for (int dr = -ViewRadius; dr <= ViewRadius; dr++)
            {
                int hexDist = Math.Max(Math.Abs(dq), Math.Max(Math.Abs(dr), Math.Abs(dq + dr)));
                int tq = Player.Q + dq, tr = Player.R + dr;
                var (cx, cy) = TileCenter(tq, tr);

                bool inFog = RevealedTiles != null && !RevealedTiles.Contains((tq, tr));
                if (hexDist > ViewRadius || !_tileMap.TryGetValue((tq, tr), out var tile) || inFog)
                {
                    <polygon @key="@($"fog_{tq}_{tr}")"
                             points="@HexPoints(cx, cy)"
                             class="hex-fog" />
                }
                else
                {
                    bool isPlayerTile = tq == Player.Q && tr == Player.R;
                    bool isAdjacent = MovementService.AreAdjacent(Player.Q, Player.R, tq, tr);
                    bool isHovered = _hoveredTile?.Q == tq && _hoveredTile?.R == tr;
                    var featureDef = FeatureProvider.GetById(tile.FeatureId);

                    <g @key="@($"{tq}_{tr}")"
                       class="hex-group @(isHovered ? "hovered" : "") @(isAdjacent ? "adjacent" : "")"
                       @onclick="() => OnTileClicked.InvokeAsync((tq, tr))">
                        <polygon points="@HexPoints(cx, cy)"
                                 class="hex-tile biome-@tile.Biome.ToString().ToLower()" />

                        @if (featureDef != null)
                        {
                            <circle cx="@cx.ToString("F1")" cy="@((cy + HexSize * 0.52).ToString("F1"))"
                                    r="4"
                                    class="feature-dot feature-@featureDef.Category.ToString().ToLower()" />
                        }

                        @if (isPlayerTile)
                        {
                            <circle cx="@cx.ToString("F1")" cy="@cy.ToString("F1")"
                                    r="@(HexSize * 0.35)"
                                    class="player-dot self"
                                    style="fill: @Player.Color" />
                        }

                        @{
                            var others = OnlinePlayers.Where(p => p.Q == tq && p.R == tr).ToList();
                            @for (int i = 0; i < Math.Min(others.Count, 4); i++)
                            {
                                double ox = cx + (i % 2 == 0 ? -6 : 6);
                                double oy = cy + (i < 2 ? -6 : 6);
                                <circle @key="others[i].Id"
                                        cx="@ox.ToString("F1")" cy="@oy.ToString("F1")"
                                        r="@(HexSize * 0.22)"
                                        class="player-dot other"
                                        style="fill: @others[i].Color">
                                    <title>@others[i].Username</title>
                                </circle>
                            }
                        }
                    </g>
                }
            }
        }

        @if (_hoveredTile != null)
        {
            var (hx, hy) = TileCenter(_hoveredTile.Q, _hoveredTile.R);
            double tx = hx + 4, ty = hy - HexSize - 4;
            var hoveredFeature = FeatureProvider.GetById(_hoveredTile.FeatureId);
            var featurePart = hoveredFeature != null
                ? $" · {hoveredFeature.GetDisplayName(_hoveredTile.Q, _hoveredTile.R)}"
                : "";
            var eggPart = _hoveredTile.EggCount > 0 ? $" 🥚×{_hoveredTile.EggCount}" : "";
            <svg:text x="@tx.ToString("F0")" y="@ty.ToString("F0")" class="tile-tooltip">
                @($"{_hoveredTile.Biome} ({_hoveredTile.Q},{_hoveredTile.R}){featurePart}{eggPart}")
            </svg:text>
        }
    </svg>
</div>

@code {
    [Parameter, EditorRequired] public Player Player { get; set; } = null!;
    [Parameter] public EventCallback<(int q, int r)> OnTileClicked { get; set; }
    [Parameter] public List<(string Id, string Username, int Q, int R, string Color)> OnlinePlayers { get; set; } = [];
    [Parameter] public IReadOnlySet<(int, int)>? RevealedTiles { get; set; }

    private const double HexSize = 32;
    private const int ViewRadius = 9;

    private double _svgWidth;
    private double _svgHeight;
    private Dictionary<(int, int), HexTile> _tileMap = [];
    private HexTile? _hoveredTile;
    private ElementReference _container;

    private static readonly double Sqrt3 = Math.Sqrt(3);

    protected override void OnParametersSet()
    {
        _svgWidth  = (ViewRadius * 2 + 1) * HexSize * Sqrt3 + HexSize;
        _svgHeight = (ViewRadius * 2 + 1) * HexSize * 1.5  + HexSize;
        var tiles = MapCache.GetViewportTiles(Player.Q, Player.R, ViewRadius, ViewRadius);
        _tileMap = tiles.ToDictionary(t => (t.Q, t.R));
    }

    private (double cx, double cy) TileCenter(int q, int r)
    {
        double cx = _svgWidth  / 2 + HexSize * Sqrt3 * (q - Player.Q) + HexSize * Sqrt3 / 2 * (r - Player.R);
        double cy = _svgHeight / 2 + HexSize * 1.5 * (r - Player.R);
        return (cx, cy);
    }

    private static string HexPoints(double cx, double cy)
    {
        var sb = new System.Text.StringBuilder();
        for (int i = 0; i < 6; i++)
        {
            double angle = Math.PI / 180 * (60 * i - 30);
            double x = cx + HexSize * Math.Cos(angle);
            double y = cy + HexSize * Math.Sin(angle);
            if (i > 0) sb.Append(' ');
            sb.Append($"{x:F1},{y:F1}");
        }
        return sb.ToString();
    }

    private void HandleMouseMove(MouseEventArgs e)
    {
        double mx = e.OffsetX - _svgWidth  / 2;
        double my = e.OffsetY - _svgHeight / 2;

        double fq = (mx * Sqrt3 / 3 - my / 3) / HexSize;
        double fr = my * 2 / 3 / HexSize;
        var (q, r) = AxialRound(fq + Player.Q, fr + Player.R);

        int dq = q - Player.Q, dr = r - Player.R;
        int hexDist = Math.Max(Math.Abs(dq), Math.Max(Math.Abs(dr), Math.Abs(dq + dr)));
        bool revealed = RevealedTiles == null || RevealedTiles.Contains((q, r));
        _hoveredTile = hexDist <= ViewRadius && revealed ? MapCache.GetCachedTile(q, r) : null;
    }

    private static (int q, int r) AxialRound(double fq, double fr)
    {
        double fs = -fq - fr;
        int q = (int)Math.Round(fq);
        int r = (int)Math.Round(fr);
        int s = (int)Math.Round(fs);

        double dq = Math.Abs(q - fq);
        double dr = Math.Abs(r - fr);
        double ds = Math.Abs(s - fs);

        if (dq > dr && dq > ds) q = -r - s;
        else if (dr > ds) r = -q - s;

        return (q, r);
    }
}
